<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Microphone access for live transcription -->
  <key>com.apple.security.device.audio-input</key>
  <true/>

  <!-- Read/write access to user-selected files (Obsidian vault) -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>

  <!-- Downloads folder access (for model weights via HuggingFace Hub) -->
  <key>com.apple.security.files.downloads.read-write</key>
  <true/>

  <!-- Outbound network connections (Google AI API) -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Allow JIT compilation (required by PyTorch MPS backend) -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Allow unsigned executable memory (required by some torch ops) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
</dict>
</plist>
